# ======================================
# TRADING EXCHANGE CONFIGURATION
# ======================================

# CCXT Exchange Configuration
EXCHANGE_ID=binance
EXCHANGE_SANDBOX=false
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET_KEY=your_secret_key_here
EXCHANGE_PASSPHRASE=your_passphrase_here  # For some exchanges like OKX

# ======================================
# TRADING MODE CONFIGURATION
# ======================================

TRADING_MODE=backtest  # Options: backtest, forward, paper, live
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,PAXGUSDT
TRADING_LEVERAGE=50

# ======================================
# NOTIFICATION CONFIGURATION
# ======================================

# Telegram Bot Configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Webhook Configuration
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=your_webhook_url_here

# ======================================
# LOGGING CONFIGURATION
# ======================================

LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH=logs/trading_bot.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ======================================
# BACKTESTING CONFIGURATION
# ======================================

BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_BALANCE=10000
BACKTEST_COMMISSION=0.001  # 0.1%

# ======================================
# PAPER TRADING CONFIGURATION
# ======================================

PAPER_TRADING_INITIAL_BALANCE=10000
PAPER_TRADING_COMMISSION=0.001

# ======================================
# RISK MANAGEMENT CONFIGURATION
# ======================================

# Daily loss limit (in percentage of account)
DAILY_LOSS_LIMIT_PERCENT=5

# Maximum trades per day
MAX_TRADES_PER_DAY=10

# Position size (percentage of account)
POSITION_SIZE_PERCENT=2

# ======================================
# STRATEGY CONFIGURATION
# ======================================

# BTCUSDT Configuration
BTCUSDT_ENABLED=true
BTCUSDT_TIMEFRAME=15m
BTCUSDT_EMA_FAST=24
BTCUSDT_EMA_SLOW=50
BTCUSDT_TAKE_PROFIT_PERCENT=3
BTCUSDT_LEVERAGE=50

# ETHUSDT Configuration
ETHUSDT_ENABLED=true
ETHUSDT_TIMEFRAME=1h
ETHUSDT_EMA_FAST=44
ETHUSDT_EMA_SLOW=88
ETHUSDT_TAKE_PROFIT_PERCENT=3
ETHUSDT_LEVERAGE=50

# PAXGUSDT Configuration
PAXGUSDT_ENABLED=true
PAXGUSDT_TIMEFRAME=5m
PAXGUSDT_EMA_FAST=44
PAXGUSDT_EMA_SLOW=100
PAXGUSDT_TAKE_PROFIT_PERCENT=3
PAXGUSDT_LEVERAGE=50

# ======================================
# DATABASE CONFIGURATION
# ======================================

# SQLite for local storage
DATABASE_TYPE=sqlite
DATABASE_PATH=data/trading_bot.db

# ======================================
# DEBUGGING
# ======================================

DEBUG_MODE=false
DEBUG_PRINT_SIGNALS=false
DEBUG_PRINT_ORDERS=false
